APP_ENV=production
POSTGRES_PASSWORD=replace-with-strong-password
JWT_SECRET_KEY=replace-with-strong-random-secret
DATABASE_URL=postgresql+psycopg://bmi:replace-with-strong-password@postgres:5432/bookmyinterview
VITE_API_BASE_URL=https://api.bookmyinterview.example
CORS_ALLOW_ORIGINS=https://app.bookmyinterview.example,https://admin.bookmyinterview.example
ENCRYPTION_KEY=replace-with-managed-secret
LLM_PROVIDER=mock
VECTOR_PROVIDER=mock
MONTHLY_PLATFORM_BUDGET_USD=100
# In production, legacy /api/workspace and /api/data are blocked by APP_ENV=production.
# Use /api/auth and /api/secure/workspace for product flows.
